# local or staging
E2E_TARGET=local
E2E_WEB_ORIGIN=http://localhost:5002
E2E_API_ORIGIN=http://localhost:5001
E2E_CALLBACK_ORIGIN=http://127.0.0.1:5010
E2E_CALLBACK_LISTEN_PORT=5010
# Must equal the issuer configured by the selected API environment.
SSO_ISSUER=http://localhost:5001/api/auth
# Local Playwright starts the API with revocation delivery and loopback enabled.
# Staging must configure ENABLE_APPLICATION_REVOCATION_DELIVERY explicitly.

# Dedicated identities only. Every address must appear in the allowlist.
E2E_ACTOR_EMAIL=e2e-admin@example.com
E2E_ACTOR_PASSWORD=replace-with-a-generated-15-character-minimum-secret
E2E_ACTOR_ROLE=admin
E2E_ACTOR_NAME=E2E Admin
E2E_MEMBER_EMAIL=e2e-member@example.com
E2E_MEMBER_NAME=E2E Member
E2E_ALLOWED_ACTOR_EMAILS=e2e-admin@example.com,e2e-member@example.com
E2E_PROVISION_ACTOR=true

# Required acknowledgement for any mutating E2E run.
E2E_CONFIRM_MUTATIONS=I_UNDERSTAND_E2E_MUTATES_DATA

# Staging-only exact allowlists and direct service connections used for guarded
# actor provisioning and test-owned cleanup. Do not commit real values.
E2E_ALLOWED_WEB_ORIGINS=https://staging-sso.example.com
E2E_ALLOWED_API_ORIGINS=https://staging-api.example.com
E2E_ALLOWED_CALLBACK_ORIGINS=https://e2e-callback.example.com
E2E_KNOWN_PRODUCTION_ORIGINS=https://sso.example.com,https://api.example.com
E2E_DATABASE_URL=
E2E_REDIS_URL=
E2E_ALLOWED_DATABASE_HOSTS=staging-db.example.com
E2E_ALLOWED_REDIS_HOSTS=staging-redis.example.com

# Optional. Generated automatically when omitted.
E2E_RUN_ID=
E2E_SLOW_MO=0
E2E_SHOW_CURSOR=true
