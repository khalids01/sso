{
  "name": "@sso/e2e",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun run scripts/run-playwright.ts",
    "test:headed": "bun run scripts/run-playwright.ts --headed",
    "test:ui": "bun run scripts/run-playwright.ts --ui",
    "test:debug": "bun run scripts/run-playwright.ts --debug",
    "test:unit": "bun test ./unit",
    "report": "playwright show-report",
    "cleanup": "bun run scripts/cleanup-run.ts",
    "install:browsers": "playwright install chromium",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@db": "workspace:*",
    "@env": "workspace:*",
    "@redis": "workspace:*",
    "@rbac": "workspace:*",
    "better-auth": "^1.4.18",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/bun": "^1.3.9",
    "jose": "^6.1.0",
    "typescript": "^6.0.2"
  }
}
