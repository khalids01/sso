model Application {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String?
  status           String   @default("active")
  logoUrl          String?
  homepageUrl      String?
  signInMethods    String[] @default(["magic_link", "password"])
  signUpMethods    String[] @default(["magic_link"])
  registrationMode String   @default("closed")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clients              ApplicationClient[]
  members              ApplicationMember[]
  subjects             ApplicationSubject[]
  revocationEndpoint   ApplicationRevocationEndpoint?
  revocationDeliveries ApplicationRevocationDelivery[]
  invitations          ApplicationInvitation[]

  @@index([status])
  @@map("application")
}

model ApplicationInvitation {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  email         String
  status        String      @default("pending")
  expiresAt     DateTime
  inviterId     String
  inviter       User        @relation("ApplicationInvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  acceptedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([applicationId, email, status])
  @@index([expiresAt])
  @@index([inviterId])
  @@map("application_invitation")
}

model ApplicationMember {
  id                   String      @id @default(cuid())
  applicationId        String
  application          Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId               String
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status               String      @default("active")
  authorizationVersion Int         @default(1)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  revocationDeliveries ApplicationRevocationDelivery[]

  @@unique([applicationId, userId])
  @@index([applicationId])
  @@index([userId])
  @@index([status])
  @@map("application_member")
}

model ApplicationRevocationEndpoint {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  url           String
  enabled       Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  deliveries ApplicationRevocationDelivery[]

  @@index([enabled])
  @@map("application_revocation_endpoint")
}

model ApplicationRevocationDelivery {
  id                   String                         @id @default(cuid())
  applicationId        String
  application          Application                    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  endpointId           String?
  endpoint             ApplicationRevocationEndpoint? @relation(fields: [endpointId], references: [id], onDelete: SetNull)
  membershipId         String?
  membership           ApplicationMember?             @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  destinationUrl       String
  eventType            String                         @default("application.access.revoked")
  reason               String
  subject              String?
  authorizationVersion Int?
  effectiveAt          DateTime
  status               String                         @default("pending")
  attemptCount         Int                            @default(0)
  nextAttemptAt        DateTime                       @default(now())
  leaseUntil           DateTime?
  deadlineAt           DateTime
  deliveredAt          DateTime?
  lastHttpStatus       Int?
  lastErrorCode        String?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  @@index([status, nextAttemptAt])
  @@index([applicationId, createdAt])
  @@index([endpointId])
  @@index([membershipId])
  @@map("application_revocation_delivery")
}

model ApplicationSubject {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       String      @unique
  createdAt     DateTime    @default(now())

  @@unique([applicationId, userId])
  @@index([applicationId])
  @@index([userId])
  @@map("application_subject")
}

model ApplicationClient {
  id                      String      @id @default(cuid())
  applicationId           String
  application             Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  clientId                String      @unique
  name                    String
  clientType              String      @default("public")
  status                  String      @default("active")
  oauthDisabled           Boolean     @default(false)
  skipConsent             Boolean     @default(true)
  enableEndSession        Boolean     @default(false)
  scopes                  String[]    @default(["openid"])
  tokenEndpointAuthMethod String      @default("none")
  grantTypes              String[]    @default(["authorization_code"])
  responseTypes           String[]    @default(["code"])
  public                  Boolean     @default(true)
  metadata                Json?
  redirectUris            String[]
  allowedOrigins          String[]
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  oauthConsents OAuthConsent[]

  @@index([applicationId])
  @@index([status])
  @@map("application_client")
}

model OAuthConsent {
  id          String            @id @default(cuid())
  clientId    String
  client      ApplicationClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  userId      String?
  user        User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  referenceId String?
  scopes      String[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([clientId])
  @@index([userId])
  @@map("oauth_consent")
}
