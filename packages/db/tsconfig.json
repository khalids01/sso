{
  "extends": "../config/tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "..",
    "composite": true,
    "paths": {
      "@env/*": ["../env/src/*"],
      "@config": ["../config/src/config.ts"],
      "@rbac": ["../rbac/src"],
      "@redis": ["../redis/src"]
    }
  },
  "include": [
    "src/**/*",
    "prisma/generated/**/*",
    "prisma/seed/**/*",
    "../env/src/**/*",
    "../config/src/**/*",
    "../rbac/src/**/*",
    "../redis/src/**/*"
  ]
}
