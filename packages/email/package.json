{
  "name": "@email",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./server": {
      "default": "./src/index.server.ts"
    },
    "./templates/*": {
      "default": "./src/templates/*.tsx"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "check-types": "tsc --noEmit",
    "email:dev": "bunx react-email dev --dir src/templates"
  },
  "dependencies": {
    "@env": "workspace:*",
    "@react-email/components": "^1.0.12",
    "nodemailer": "^9.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@react-email/ui": "6.9.0",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^8.0.0",
    "react-email": "^6.9.0",
    "typescript": "^6.0.2"
  }
}
