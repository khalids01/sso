{
  "name": "sso",
  "author": {
    "name": "Khalid",
    "email": "khalidcode03@gmail.com",
    "url": "https://github.com/khalids01"
  },
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tests/*"
    ],
    "catalog": {
      "dotenv": "^17.3.1",
      "zod": "^4.3.6",
      "typescript": "^6.0.2",
      "@types/bun": "^1.3.9",
      "better-auth": "1.6.23",
      "@prisma/client": "^7.4.0",
      "@polar-sh/better-auth": "^1.8.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:studio": "turbo -F @db db:studio",
    "db:generate": "turbo -F @db db:generate",
    "db:reset": "turbo -F @db db:reset",
    "db:migrate": "turbo -F @db db:migrate",
    "db:seed": "bun --cwd packages/db --env-file ../../apps/server/.env db:seed",
    "make-owner": "bun run packages/db/scripts/make-owner.ts",
    "e2e": "bun --cwd tests/e2e test",
    "e2e:headed": "DISPLAY=:1 XAUTHORITY=/run/user/1000/gdm/Xauthority E2E_SLOW_MO=300 bun --cwd tests/e2e test:headed",
    "e2e:ui": "DISPLAY=:1 XAUTHORITY=/run/user/1000/gdm/Xauthority bun --cwd tests/e2e test:ui",
    "e2e:debug": "bun --cwd tests/e2e test:debug",
    "e2e:report": "bun --cwd tests/e2e report",
    "e2e:cleanup": "bun --cwd tests/e2e cleanup",
    "e2e:install": "bun --cwd tests/e2e install:browsers"
  },
  "dependencies": {
    "@env": "workspace:*",
    "@t3-oss/env-core": "^0.13.10",
    "dotenv": "^17.3.1",
    "nodemailer": "^9.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@config": "workspace:*",
    "@types/bun": "^1.3.9",
    "turbo": "^2.10.5",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.3"
}
